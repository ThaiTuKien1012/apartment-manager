PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ai-image-retrieval
OPENAI_API_KEY=your_openai_api_key

# Google AI Studio (Gemini) — free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
# Tuỳ chọn — gemini-1.5-flash có thể 404 trên API mới; dùng ví dụ:
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-flash-latest
GEMINI_MODEL=gemini-2.5-flash-lite

# Supabase Storage (tuỳ chọn). Nếu set đủ 3 biến, ảnh upload mới sẽ lưu cloud thay vì local uploads/.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=apartment-images
